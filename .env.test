# pac1-py/.env — не коммитить в git. Credentials → .secrets.
# Приоритет: env > .secrets > .env

# ─── Общее ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG → логировать RAW LLM-ответы
TZ=                                  # пусто = системный

# ─── Benchmark ──────────────────────────────────────────────────────────────
BENCHMARK_HOST=https://api.bitgn.com
BENCHMARK_ID=bitgn/ecom1-dev
BITGN_RUN_NAME=ecom1-dev-agent-ikeniborn
BITGN_API_KEY=bgn-7guqyGuHFYWPFtDu69JfKooVmPq7nr
TASK_TIMEOUT_S=1200
PARALLEL_TASKS=5
MAX_STEPS=5

# ─── Модель ─────────────────────────────────────────────────────────────────
MODEL=claude-code/sonnet-4.6

# ─── Режим отладки ──────────────────────────────────────────────────────────
DRY_RUN=0                            # 1 = только prephase, нет LLM-вызовов, пишет data/dry_run_analysis.jsonl

# ─── Ollama ─────────────────────────────────────────────────────────────────
# Модели формата name:tag (без слэша) → Ollama. Примеры: qwen3.5:cloud.
OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Claude Code tier (опционально) ─────────────────────────────────────────
# Активируется префиксом claude-code/* в MODEL.
CC_ENABLED=1
ICLAUDE_CMD=/home/UF.RT.RU/i.y.tischenko/Документы/Git/iclaude/iclaude.sh
CC_MAX_RETRIES=3


# ─── Evaluator ────────────────────────────────────────────────────────────────
EVAL_ENABLED=1                                                                                                                                                                 
MODEL_EVALUATOR=claude-code/opus-4.7