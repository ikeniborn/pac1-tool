{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Wiki Domain Map",
  "version": "1.0.0",
  "wiki_root": ".wiki",
  "domains": [
    {
      "id": "документация",
      "name": "Документация ecom1-agent",
      "description": "Дизайн-документы, планы реализации и архитектурные решения по проекту ecom1-agent",
      "source_paths": ["docs/"],
      "tags": ["ecom1-agent", "documentation"],
      "language_notes": "Технические термины — на английском, пояснительный текст — на русском",
      "entity_types": [
        {
          "type": "spec",
          "description": "Дизайн-документ — архитектурное решение с описанием компонентов, моделей и контрактов",
          "extraction_cues": ["Design", "Spec", "Status: Approved", "Scope:", "Problem", "Solution", "Architecture", "Module Map"],
          "min_mentions_for_page": 1,
          "wiki_subfolder": "документация/specs"
        },
        {
          "type": "plan",
          "description": "План реализации — пошаговый список задач с checkbox-синтаксисом",
          "extraction_cues": ["Implementation Plan", "- [ ]", "Goal:", "superpowers:executing-plans", "Steps"],
          "min_mentions_for_page": 1,
          "wiki_subfolder": "документация/plans"
        },
        {
          "type": "pipeline-phase",
          "description": "Фаза детерминированного SQL-пайплайна агента",
          "extraction_cues": ["SQL_PLAN", "VALIDATE", "EXECUTE", "LEARN", "ANSWER", "EVALUATE", "SGR", "phase", "cycle"],
          "min_mentions_for_page": 3,
          "wiki_subfolder": "документация/pipeline-phases"
        },
        {
          "type": "agent-module",
          "description": "Модуль агента — Python-файл с конкретной ответственностью в pipeline",
          "extraction_cues": ["pipeline.py", "llm.py", "prephase.py", "evaluator.py", "orchestrator.py", "sql_security.py", "json_extract.py", "models.py", "rules_loader.py"],
          "min_mentions_for_page": 3,
          "wiki_subfolder": "документация/agent-modules"
        },
        {
          "type": "design-decision",
          "description": "Архитектурное решение — выбор подхода с обоснованием",
          "extraction_cues": ["SGR pattern", "security gates", "subtype system", "verified:", "LEARN phase", "eval-driven", "grounding_refs", "schema_gate"],
          "min_mentions_for_page": 2,
          "wiki_subfolder": "документация/design-decisions"
        }
      ]
    }
  ],
  "cross_domain_rules": {
    "description": "Правила для сущностей, встречающихся в нескольких доменах",
    "rules": []
  },
  "special_source_types": {},
  "source_types": {
    ".md": {
      "reader": "markdown",
      "extract": ["narrative", "frontmatter", "code_blocks", "headings"],
      "rules_file": "rules/readers/markdown.md"
    },
    ".py": {
      "reader": "python",
      "extract": ["public_api", "docstrings", "types", "imports"],
      "rules_file": "rules/readers/python.md"
    },
    ".ts": {
      "reader": "typescript",
      "extract": ["public_api", "docstrings", "types", "imports"],
      "rules_file": "rules/readers/typescript.md"
    },
    ".tsx": {
      "reader": "typescript",
      "extract": ["public_api", "docstrings", "types", "imports"],
      "rules_file": "rules/readers/typescript.md"
    },
    ".js": {
      "reader": "javascript",
      "extract": ["public_api", "docstrings", "imports"],
      "rules_file": "rules/readers/javascript.md"
    },
    ".mjs": {
      "reader": "javascript",
      "extract": ["public_api", "docstrings", "imports"],
      "rules_file": "rules/readers/javascript.md"
    },
    ".sh": {
      "reader": "bash",
      "extract": ["functions", "flags", "exports", "comments"],
      "rules_file": "rules/readers/bash.md"
    }
  }
}
