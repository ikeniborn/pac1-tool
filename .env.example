# pac1-py/.env — не коммитить в git
# Настройки без credentials. Credentials → .secrets
#
# Приоритет загрузки:
# 1. переменные окружения (env)
# 2. .secrets
# 3. .env (этот файл — загружается первым, перекрывается .secrets и env)

# ─── Общее ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG          # DEBUG — логирует RAW ответы LLM и полные thinking-блоки
TZ=                     # Часовой пояс для timestamps логов (пусто = системный)

# ─── Benchmark ───────────────────────────────────────────────────────────────
BENCHMARK_HOST=https://api.bitgn.com
BENCHMARK_ID=bitgn/pac1-dev
BITGN_RUN_NAME=pac1-dev-your-name    # Имя запуска (отображается в отчёте bitgn)
TASK_TIMEOUT_S=300                   # Таймаут одной задачи в секундах
PARALLEL_TASKS=2                     # Кол-во параллельных задач (min 1).
                                     # ВАЖНО для RESEARCHER_MODE=1: ставить 1 —
                                     # иначе параллельные задачи все загружают
                                     # graph.json/pages одновременно при старте
                                     # и не видят успешных паттернов друг друга.

# ─── Роутинг ─────────────────────────────────────────────────────────────────
ROUTER_FALLBACK=CLARIFY   # Стратегия при неясном типе задачи: CLARIFY | EXECUTE
ROUTER_MAX_RETRIES=2      # Макс. попыток классификации задачи

# ─── Модели ──────────────────────────────────────────────────────────────────
# Обязательные (агент не запустится без них):
#   MODEL_CLASSIFIER  — лёгкая модель только для классификации задания
#   MODEL_DEFAULT     — fallback для всех типов задач
#
# FIX-325: task-type registry. Список типов задаётся в data/task_types.json.
# Каждая запись имеет поле model_env (по конвенции MODEL_<UPPER_TYPE>). Новый
# тип автоматически подхватывается ModelRouter'ом — достаточно добавить его в
# data/task_types.json и, если нужно, объявить MODEL_<UPPER> ниже. Legacy-имена
# (MODEL_EMAIL/MODEL_LOOKUP/…) имеют приоритет над конвенцией для обратной
# совместимости.
#
# Опциональные (fallback если не заданы):
#   MODEL_EMAIL     → fallback: MODEL_DEFAULT
#   MODEL_LOOKUP    → fallback: MODEL_DEFAULT
#   MODEL_INBOX     → fallback: MODEL_DEFAULT
#   MODEL_QUEUE     → fallback: MODEL_INBOX (batch-обработка очереди)
#   MODEL_CAPTURE   → fallback: MODEL_DEFAULT (explicit snippet → vault path)
#   MODEL_CRM       → fallback: MODEL_DEFAULT (reschedule/follow-up date arithmetic)
#   MODEL_TEMPORAL  → fallback: MODEL_LOOKUP  (дата-относительные запросы)
#   MODEL_PREJECT   → fallback: MODEL_DEFAULT (immediate rejection, 1 шаг)
#   MODEL_DISTILL   → fallback: MODEL_DEFAULT (анализ + запись карточки/заметки)
#   MODEL_EVALUATOR      → fallback: MODEL_DEFAULT
#   MODEL_PROMPT_BUILDER → fallback: MODEL_CLASSIFIER  (inference, каждый прогон)
#   MODEL_OPTIMIZER      → fallback: MODEL_CLASSIFIER  (только для optimize_prompts.py)
#   MODEL_WIKI           → fallback: MODEL_DEFAULT     (wiki-lint до/после прогона)
#   MODEL_RESEARCHER     → fallback: ModelRouter по task_type (researcher mode, FIX-362)
#
MODEL_CLASSIFIER=anthropic/claude-haiku-4.5
MODEL_DEFAULT=anthropic/claude-sonnet-4.6
# MODEL_EMAIL=anthropic/claude-haiku-4.5
# MODEL_LOOKUP=anthropic/claude-haiku-4.5
# MODEL_INBOX=anthropic/claude-sonnet-4.6
# MODEL_QUEUE=
# MODEL_CAPTURE=
# MODEL_CRM=
# MODEL_TEMPORAL=
# MODEL_PREJECT=anthropic/claude-haiku-4.5
# MODEL_EVALUATOR=
# MODEL_PROMPT_BUILDER=
# MODEL_OPTIMIZER=      # модель для optimize_prompts.py; по умолчанию MODEL_CLASSIFIER
# MODEL_WIKI=           # модель для wiki-lint (FIX-103/FIX-105); по умолчанию MODEL_DEFAULT
# MODEL_RESEARCHER=     # модель для researcher mode (FIX-362); пусто = ModelRouter по task_type
#                       # поддерживает claude-code/* при CC_ENABLED=1

# ─── Classifier (DSPy ChainOfThought) ───────────────────────────────────────
CLASSIFIER_MAX_TOKENS=256  # Токен-бюджет для DSPy-классификатора (CoT требует токены на reasoning)
# FIX-N+2: majority-vote против CC-недетерминизма. Активно только на CC tier
# (provider='claude-code'). Значение >=2 включает N независимых классификаций и
# возвращает моду. По умолчанию: 3 на CC, 1 на других tier (они детерминированы).
# Раскомментируйте, чтобы переопределить.
# CLASSIFIER_VOTES=3

# ─── Evaluator / Critic (DSPy ChainOfThought) ────────────────────────────────
EVALUATOR_ENABLED=1        # 1 = включить проверку результата перед report_completion
EVAL_SKEPTICISM=mid        # Строгость оценки: low | mid | high
EVAL_EFFICIENCY=mid        # Глубина контекста для оценщика: low | mid | high
EVAL_MAX_REJECTIONS=2      # Макс. отклонений до принудительного approve
# Скомпилированная программа: data/evaluator_program.json (загружается автоматически)
# FIX-367: инъекция знаний researcher-а в контекст evaluator-а
EVALUATOR_WIKI_ENABLED=1       # 1 = подмешивать pages/<task_type>.md (Successful + Verified refusal)
EVALUATOR_WIKI_MAX_CHARS=4000  # Лимит символов на wiki-патчу (обрезается хвост)
EVALUATOR_GRAPH_TOP_K=5        # Top-K узлов из wiki_graph (переиспользует WIKI_GRAPH_ENABLED)

# ─── Prompt Builder (DSPy Predict) ───────────────────────────────────────────
PROMPT_BUILDER_ENABLED=1      # 1 = генерировать динамический addendum к промпту
PROMPT_BUILDER_MAX_TOKENS=500  # Токен-бюджет для addendum (500 = ~8 пунктов)
# Скомпилированная программа: data/prompt_builder_program.json (загружается автоматически)
#
# Цикл оптимизации (DSPy COPRO):
#   1. Прогоны main.py накапливают:
#      - data/dspy_examples.jsonl      (builder, ≥ 30 примеров)
#      - data/dspy_eval_examples.jsonl (evaluator, ≥ 20 примеров, только если EVALUATOR_ENABLED=1)
#   2. При достижении порога: uv run python optimize_prompts.py --target all
#   3. Сохраняет data/*.json — агент подхватывает при следующем старте
#   До порога: builder использует data/dspy_synthetic.jsonl (cold-start),
#              evaluator использует 4 hardcoded bootstrap-примера

# ─── DSPy — сбор примеров ────────────────────────────────────────────────────
DSPY_COLLECT=1   # 1 = собирать примеры после каждого прогона, 0 = не собирать
#                  Собирает: data/dspy_examples.jsonl (builder) + data/dspy_eval_examples.jsonl (evaluator)
#                  vault_tree / agents_md НЕ персистятся — PAC-1 fixed-vault, они near-constant
#                  и раздувают примеры; vault-семантика живёт в Signature instructions
#
#                  ВАЖНО: при RESEARCHER_MODE=1 сбор DSPy-примеров фактически
#                  выключен даже с DSPY_COLLECT=1. Researcher mode не вызывает
#                  prompt_builder (builder_used=False) и не вызывает evaluator
#                  (evaluator_calls=0), поэтому в dspy_examples.jsonl и
#                  dspy_eval_examples.jsonl ничего не пишется. Знания researcher-
#                  прогонов идут через другой канал: data/wiki/pages/<type>.md
#                  (Successful + Verified refusal) и data/wiki/graph.json.
#                  Для пополнения DSPy-корпуса и рекомпиляции program.json через
#                  optimize_prompts.py нужно гонять normal mode (RESEARCHER_MODE=0).

# ─── DSPy COPRO — параметры оптимизатора (optimize_prompts.py) ───────────────
# Offline-оптимизация инструкций для prompt_builder и evaluator.
# Запускается вручную: uv run python optimize_prompts.py --target all
#
# Модель для DSPy-оптимизации
#   Приоритет разрешения: MODEL_OPTIMIZER → MODEL_CLASSIFIER → MODEL_DEFAULT.
#   COPRO делает ~ BREADTH × DEPTH × |trainset| вызовов LLM — стоимость растёт быстро,
#   поэтому рекомендуется лёгкая быстрая модель (haiku / qwen:cloud / локальная).
#   Отличается от MODEL_PROMPT_BUILDER (runtime-генерация addendum на каждом прогоне) —
#   MODEL_OPTIMIZER используется только в optimize_prompts.py.
# MODEL_OPTIMIZER=anthropic/claude-haiku-4.5
#
# Claude Code tier совместим с DSPy через DispatchLM → dispatch.call_llm_raw().
# Примеры:
#   MODEL_EVALUATOR=claude-code/haiku-4.5      # быстрая проверка
#   MODEL_PROMPT_BUILDER=claude-code/haiku-4.5 # runtime-генерация addendum
#   MODEL_OPTIMIZER=claude-code/haiku-4.5      # COPRO — чувствителен к latency
# Внимание: COPRO делает тысячи вызовов; iclaude — subprocess с высокой latency
# старта. Для больших trainset лучше anthropic-tier или локальная ollama.
#
# COPRO_BREADTH=4
#   Количество кандидатов-инструкций, генерируемых на каждой итерации.
#   Больше → шире поиск и качественнее итоговая инструкция, но линейный рост числа вызовов.
#   Типичный диапазон: 3–10. Для smoke-теста можно опустить до 2.
#
# COPRO_DEPTH=2
#   Количество итераций (раундов уточнения инструкций поверх лучших кандидатов).
#   Больше → глубже сходимость, но стоимость растёт мультипликативно с BREADTH.
#   Типичный диапазон: 1–5. DEPTH=1 — быстрая проверка пайплайна без настоящей оптимизации.
#
# COPRO_TEMPERATURE=0.9
#   Температура LLM при генерации кандидатов инструкций (0.0–2.0).
#   Выше → разнообразнее формулировки (exploration), ниже → консервативнее (exploitation).
#   0.9 — дефолт DSPy. Снижайте до 0.6–0.7, если кандидаты «разбегаются» по смыслу;
#   поднимайте до 1.1–1.3 при застревании в локальном оптимуме.
#
# COPRO_THREADS=1
#   Степень параллелизма при оценке кандидатов на trainset.
#   1 — последовательно, безопасно для API rate limits (рекомендуется по умолчанию).
#   >1 — ускоряет прогон, но требует запаса по RPM/TPM у провайдера
#   (Anthropic / OpenRouter / Ollama). Следите за 429-ответами в логах.
#
# COPRO_MIN_PER_TYPE=3
#   Минимум примеров на task_type для запуска per-type оптимизации.
#   Типы с меньшим числом примеров пропускаются (fallback на global program).
#
# COPRO_PROMPT_MAX_TOKENS=2000
#   Токен-бюджет для meta-LM, генерирующего КАНДИДАТЫ инструкций внутри COPRO.
#   Отделён от inference-бюджета (400/600/64 для builder/evaluator/classifier).
#   Низкое значение → обрезание JSON-ответа и AdapterParseError; 2000 — безопасно.
#   Поднимайте до 3000+, если кандидаты многословные (сложные task_type).
#
# Логи оптимизатора:
#   data/optimize_runs.jsonl — все события (run_start, lm_call, metric_eval, run_end, error)
#   data/dspy_errors.jsonl   — только ошибки с полным traceback (для разбора падений)

# ─── Ollama (local / cloud via Ollama-compatible endpoint) ───────────────────
# Используется автоматически для моделей формата name:tag (без слэша).
# Примеры: qwen3.5:9b, qwen3.5:cloud, deepseek-v3.1:671b-cloud
#
OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3.5:cloud

# ─── Claude Code tier (iclaude subprocess, OAuth) ────────────────────────────
# Активируется, когда MODEL_* имеет префикс claude-code/...
# Пример: MODEL_LOOKUP=claude-code/sonnet-4.6
#
# Tier запускает iclaude как stateless LLM subprocess (никакого MCP/CLAUDE.md
# auto-discovery): --no-save --print --strict-mcp-config --mcp-config <empty>
# --system-prompt <sys> --output-format json. cwd=tmpdir, env без
# ANTHROPIC/OPENROUTER/OPENAI API-ключей — iclaude использует свой OAuth.
#
# Алиасы моделей (models.json → _section_claude_code):
#   claude-code/haiku-4.5   → effort=low,    timeout=120s
#   claude-code/sonnet-4.6  → effort=medium, timeout=180s
#   claude-code/opus-4.6    → effort=high,   timeout=240s
#
# CC_ENABLED=1                       # 0/пусто = tier отключён (возвращает None)
# ICLAUDE_CMD=iclaude                # путь/alias к бинарю iclaude
# CC_STRIP_PROJECT_ENV=1             # 1 = убрать ANTHROPIC/OPENROUTER/OPENAI ключи
#                                    #     из env перед запуском subprocess
# CC_MAX_RETRIES=2                   # повторов при timeout/error/empty (итого N+1)
# CC_RETRY_DELAY_S=4                 # пауза между попытками
# CC_DEFAULT_MODEL=sonnet            # дефолт если cc_model не задан в профиле
# CC_DEFAULT_EFFORT=low              # дефолт если cc_options не задан
# CC_DEFAULT_TIMEOUT_S=180           # дефолт если cc_options не задан
#
# FIX-N+1: дополнительные CC-флаги (пробрасываются в iclaude CLI).
# Все OAuth-совместимы; --bare НЕ поддерживается (ломает OAuth).
# Значения по умолчанию применяются, когда в cc_options профиля не задан ключ.
# CC_DEFAULT_FALLBACK_MODEL=         # --fallback-model <id>, автозамена при overload
#                                    # (пример: "haiku"). Пусто = без fallback.
# CC_DEFAULT_EXCLUDE_DYNAMIC=1       # 1 = --exclude-dynamic-system-prompt-sections;
#                                    # убирает cwd/env/git из system prompt → лучше
#                                    # prompt-cache reuse между прогонами.
#
# Ключи в models.json:_profiles и per-model cc_options:
#   cc_effort, cc_timeout_s          — уже были
#   cc_fallback_model                — FIX-N+1: строка, --fallback-model
#   cc_exclude_dynamic               — FIX-N+1: bool, --exclude-dynamic-system-prompt-sections
#   cc_json_schema                   — FIX-N+1: raw JSON schema, --json-schema
#                                      (используется классификатором через cc_options_classifier)
# Per-model override для классификатора: "cc_options_classifier": "cc_classifier"
# подставляет профиль cc_classifier (low effort + json_schema на task_type).

# ─── Researcher mode (FIX-362) ───────────────────────────────────────────────
# Альтернативный режим исполнения: внешний цикл поверх run_loop, без evaluator,
# stall-detector и TASK_TIMEOUT_S. Между циклами reflector формирует journal-
# запись (fragments/research/<type>/), вики-граф обновляется, промпт перестраи-
# вается. Успешная траектория попадает в pages/<type>.md как `## Successful
# pattern:`. Вкл./выкл. только через RESEARCHER_MODE=1 — normal-режим не затро-
# нут. Стоимость выше (×циклы), поэтому режим предназначен для сбора данных и
# ручного разбора сложных задач, а не для production-прогона.
#
# RESEARCHER_MODE=0                    # 1 = включить режим исследователя
#                                      # ВАЖНО: выставить PARALLEL_TASKS=1 —
#                                      # иначе параллельные задачи не видят
#                                      # паттернов друг друга (все грузят
#                                      # graph.json/pages до первого save).
#                                      # ВАЖНО: DSPY_COLLECT не работает в этом
#                                      # режиме — prompt_builder и evaluator не
#                                      # вызываются, dspy_*_examples.jsonl не
#                                      # пополняются. Для DSPy-корпуса гонять
#                                      # RESEARCHER_MODE=0 (normal mode).
# RESEARCHER_MAX_CYCLES=10             # внешний лимит циклов
# RESEARCHER_STEPS_PER_CYCLE=15        # длина inner-loop (max_steps run_loop)
# MODEL_RESEARCHER=                    # модель для researcher mode (объявлена в
#                                      # секции «Модели» выше). Пусто = ModelRouter
#                                      # по task_type; поддерживает claude-code/*.
# RESEARCHER_LOG_ENABLED=1             # 1 = писать per-cycle JSON снапшоты в
#                                      # logs/researcher/<task_id>/cycle_N.jsonl
#                                      # (reflection, step_facts, done_ops,
#                                      # addendum_next — debug/post-mortem).
#                                      # 0 = отключить (директория не растёт).
#                                      # Файлы перезаписываются при повторном
#                                      # прогоне того же task_id, содержат vault-
#                                      # specific данные (в отличие от scrubbed
#                                      # fragments/research/), так что в git
#                                      # коммитить не стоит.
#
# Knowledge graph (agent/wiki_graph.py):
# WIKI_GRAPH_ENABLED=1                 # 0 = не читать/не писать data/wiki/graph.json
# WIKI_GRAPH_TOP_K=5                   # количество узлов в KNOWLEDGE GRAPH секции
# WIKI_GRAPH_CONFIDENCE_EPSILON=0.05   # шаг понижения confidence при negative исходе
# WIKI_GRAPH_MIN_CONFIDENCE=0.2        # ниже этого значения узел → graph_archive.json
# WIKI_PAGE_MAX_PATTERNS=10            # max `## Successful pattern:` секций на странице

# ─── HTTP таймауты LLM-клиентов (FIX-215) ────────────────────────────────────
# Применяются к httpx-клиентам OpenRouter/Ollama/Anthropic, чтобы зависший сокет
# не вис часами. "Timeout" ловится TRANSIENT_KWS → срабатывает retry-логика.
# LLM_HTTP_READ_TIMEOUT_S=180       # чтение ответа (дефолт 180с)
# LLM_HTTP_CONNECT_TIMEOUT_S=10     # установка соединения (дефолт 10с)
