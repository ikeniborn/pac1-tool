# pac1-py/.env — не коммитить в git. Credentials → .secrets.
# Приоритет: env > .secrets > .env

# ─── Общее ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG                      # DEBUG → логировать RAW LLM-ответы
TZ=                                  # пусто = системный

# ─── Benchmark ──────────────────────────────────────────────────────────────
BENCHMARK_HOST=https://api.bitgn.com
BENCHMARK_ID=bitgn/pac1-dev
BITGN_RUN_NAME=pac1-dev-your-name
TASK_TIMEOUT_S=300
PARALLEL_TASKS=2

# ─── Context compaction ──────────────────────────────────────────────────────
# CTX_COMPACT_THRESHOLD_PCT=0.70      # доля ctx_window при которой срабатывает компактинг

# ─── Роутинг ────────────────────────────────────────────────────────────────
ROUTER_FALLBACK=CLARIFY               # CLARIFY | EXECUTE
ROUTER_MAX_RETRIES=2

# ─── Модели ─────────────────────────────────────────────────────────────────
# Обязательные: MODEL_CLASSIFIER, MODEL_DEFAULT.
# Опциональные MODEL_<TYPE> задаются по task_types.json; пустые → fallback на MODEL_DEFAULT
# (кроме MODEL_QUEUE → MODEL_INBOX, MODEL_TEMPORAL → MODEL_LOOKUP,
#  MODEL_PROMPT_BUILDER/OPTIMIZER → MODEL_CLASSIFIER).
# Префикс claude-code/* активирует CC tier при CC_ENABLED=1.
MODEL_CLASSIFIER=anthropic/claude-haiku-4.5
MODEL_DEFAULT=anthropic/claude-sonnet-4.6
# MODEL_EMAIL=
# MODEL_LOOKUP=
# MODEL_INBOX=
# MODEL_QUEUE=
# MODEL_CAPTURE=
# MODEL_CRM=
# MODEL_TEMPORAL=
# MODEL_PREJECT=anthropic/claude-haiku-4.5
# MODEL_EVALUATOR=
# MODEL_PROMPT_BUILDER=
# MODEL_OPTIMIZER=                   # только для scripts/optimize_prompts.py
# MODEL_WIKI=                        # wiki-lint

# ─── Classifier (DSPy) ──────────────────────────────────────────────────────
CLASSIFIER_MAX_TOKENS=256
# CLASSIFIER_VOTES=3                 # majority-vote, авто включается только на CC tier

# ─── Evaluator (DSPy) ───────────────────────────────────────────────────────
EVALUATOR_ENABLED=1
EVAL_SKEPTICISM=mid                  # low | mid | high
EVAL_EFFICIENCY=mid                  # low | mid | high
EVAL_MAX_REJECTIONS=2
EVALUATOR_WIKI_ENABLED=1             # подмешивать pages/<type>.md (FIX-367)
EVALUATOR_WIKI_MAX_CHARS=4000
EVALUATOR_GRAPH_TOP_K=5              # гейчено WIKI_GRAPH_ENABLED

# ─── Prompt Builder (DSPy) ──────────────────────────────────────────────────
PROMPT_BUILDER_ENABLED=1
PROMPT_BUILDER_MAX_TOKENS=500

# ─── Contract Phase ──────────────────────────────────────────────────────────
CONTRACT_ENABLED=1                   # 1 = enable pre-execution contract negotiation
CONTRACT_MAX_ROUNDS=3                # max negotiation rounds before fallback
# MODEL_CONTRACT=openrouter/anthropic/claude-3-5-haiku  # cheap model for negotiation; falls back to MODEL_DEFAULT
OPTIMIZER_CONTRACT=copro                 # DSPy backend for contract optimization (copro|gepa)

# ─── DSPy — сбор примеров ───────────────────────────────────────────────────
DSPY_COLLECT=1                       # data/dspy_{examples,eval_examples}.jsonl

# ─── DSPy COPRO (scripts/optimize_prompts.py) ──────────────────────────────
# Запуск вручную. Стоимость ≈ BREADTH × DEPTH × |trainset| LLM-вызовов.
# COPRO_BREADTH=4                    # кандидатов на итерацию (3–10)
# COPRO_DEPTH=2                      # итераций уточнения (1–5)
# COPRO_TEMPERATURE=0.9              # 0.0–2.0
# COPRO_THREADS=1                    # параллелизм оценки; >1 → следи за 429
# COPRO_MIN_PER_TYPE=3               # минимум примеров для per-type оптимизации
# COPRO_PROMPT_MAX_TOKENS=2000       # бюджет meta-LM для кандидатов

# ─── Ollama ─────────────────────────────────────────────────────────────────
# Модели формата name:tag (без слэша) → Ollama. Примеры: qwen3.5:cloud.
OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3.5:cloud

# ─── Claude Code tier ───────────────────────────────────────────────────────
# Активируется префиксом claude-code/*. Stateless iclaude subprocess, OAuth.
# CC_ENABLED=1
# ICLAUDE_CMD=iclaude
# CC_STRIP_PROJECT_ENV=1             # убрать ANTHROPIC/OPENROUTER/OPENAI из env
# CC_MAX_RETRIES=2
# CC_RETRY_DELAY_S=4
# CC_DEFAULT_MODEL=sonnet
# CC_DEFAULT_EFFORT=low
# CC_DEFAULT_TIMEOUT_S=180
# CC_DEFAULT_FALLBACK_MODEL=         # --fallback-model (например "haiku")
# CC_DEFAULT_EXCLUDE_DYNAMIC=1       # убирает cwd/env/git → лучше cache reuse

# ─── Knowledge graph ────────────────────────────────────────────────────────
# WIKI_GRAPH_ENABLED=1               # read-side гейт: используется evaluator-ом и
#                                    # инжектом в system prompt + DSPy addendum.
# WIKI_GRAPH_TOP_K=5                 # узлов в KNOWLEDGE GRAPH секции prompt'а
# WIKI_GRAPH_CONFIDENCE_EPSILON=0.05
# WIKI_GRAPH_MIN_CONFIDENCE=0.2      # ниже → graph_archive.json
# WIKI_PAGE_MAX_PATTERNS=10          # max `## Successful pattern:` на страницу
#
# FIX-389 — write-side (normal mode):
# WIKI_GRAPH_AUTOBUILD=1             # граф пополняется в run_wiki_lint:
#                                    # LLM-синтез возвращает markdown + JSON-fence
#                                    # с graph_deltas (insights/rules/antipatterns).
# WIKI_GRAPH_FEEDBACK=1              # post-trial confidence-feedback:
#                                    # score=1 → bump_uses + add_pattern_node на
#                                    # узлы из prompt'а; score=0 → degrade_confidence
#                                    # с epsilon.
# WIKI_GRAPH_ERRORS_INGEST=0         # FIX-413: 1 = build antipattern nodes from
#                                    # archive/errors/ without LLM (conf=0.4).
#                                    # Default off — enable after first full run.

# ─── Wiki toggles ───────────────────────────────────────────────────────────
# WIKI_ENABLED=1                     # 0 = не писать fragments/ и не promote pages/
# WIKI_LINT_ENABLED=1                # 0 = пропустить wiki-lint до/после прогона
# WIKI_NEGATIVES_ENABLED=1            # 0 = не инжектировать dead ends в system prompt
# WIKI_NEGATIVES_MAX_CHARS=800        # макс символов для блока KNOWN DEAD ENDS

# ─── Tracing / debug ────────────────────────────────────────────────────────
# TRACE_ENABLED=0                    # 1 = logs/<run>/trace_<task>.jsonl
# CC_DEBUG_EMPTY=0                   # diagnostic tail при legitimately-empty CC response

# ─── HTTP таймауты LLM-клиентов ─────────────────────────────────────────────
# LLM_HTTP_READ_TIMEOUT_S=180
# LLM_HTTP_CONNECT_TIMEOUT_S=10

# ---------------------------------------------------------------------------
# DSPy optimizer selection (gepa | copro). Per-target overrides default.
# Resolution order: OPTIMIZER_<TARGET> > OPTIMIZER_DEFAULT > "copro".
# Targets: BUILDER, EVALUATOR, CLASSIFIER. Per-task_type labels (e.g.
# "builder/email") split on "/" — outer routing uses uppercased head.
# Reflection LM for GEPA reuses MODEL_OPTIMIZER (no separate variable).
# ---------------------------------------------------------------------------
OPTIMIZER_DEFAULT=copro
# OPTIMIZER_BUILDER=gepa
# OPTIMIZER_EVALUATOR=copro
# OPTIMIZER_CLASSIFIER=gepa

# GEPA budget — built-in auto preset (light | medium | heavy). Higher = больше
# rollouts на trainset = дольше + дороже. light хватает для smoke / коротких
# trainset (< 60 примеров).
GEPA_AUTO=light
# Точечный override вместо auto. Принимает один key=value:
#   max_full_evals=N   — N полных проходов по trainset
#   max_metric_calls=N — жёсткий лимит вызовов metric()
# Если задан — auto игнорируется.
# GEPA_BUDGET_OVERRIDE=

# ConfidenceAdapter для classifier-target включается автоматически, когда
# OPTIMIZER_CLASSIFIER=gepa AND провайдер MODEL_OPTIMIZER поддерживает logprobs
# (openrouter, ollama). Anthropic SDK / claude-code субпроцесс — fallback на
# JSONAdapter без warning'ов.

# Train/val split — последние GEPA_VAL_FRACTION примеров идут в valset.
# 0.0 < x < 1.0. Ниже GEPA_MIN_TRAINSET_FOR_SPLIT — split пропускается.
GEPA_VAL_FRACTION=0.2
GEPA_MIN_TRAINSET_FOR_SPLIT=20
