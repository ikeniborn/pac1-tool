# pac1-py/.env — не коммитить в git. Credentials → .secrets.
# Приоритет: env > .secrets > .env

# ─── Общее ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG                      # DEBUG → логировать RAW LLM-ответы
TZ=                                  # пусто = системный

# ─── Benchmark ──────────────────────────────────────────────────────────────
BENCHMARK_HOST=https://api.bitgn.com
BENCHMARK_ID=bitgn/pac1-dev
BITGN_RUN_NAME=pac1-dev-your-name
TASK_TIMEOUT_S=300
PARALLEL_TASKS=2                     # RESEARCHER_MODE=1 требует 1 (см. ниже)

# ─── Роутинг ────────────────────────────────────────────────────────────────
ROUTER_FALLBACK=CLARIFY               # CLARIFY | EXECUTE
ROUTER_MAX_RETRIES=2

# ─── Модели ─────────────────────────────────────────────────────────────────
# Обязательные: MODEL_CLASSIFIER, MODEL_DEFAULT.
# Опциональные MODEL_<TYPE> задаются по task_types.json; пустые → fallback на MODEL_DEFAULT
# (кроме MODEL_QUEUE → MODEL_INBOX, MODEL_TEMPORAL → MODEL_LOOKUP,
#  MODEL_PROMPT_BUILDER/OPTIMIZER → MODEL_CLASSIFIER,
#  MODEL_RESEARCHER пусто → ModelRouter по task_type).
# Префикс claude-code/* активирует CC tier при CC_ENABLED=1.
MODEL_CLASSIFIER=anthropic/claude-haiku-4.5
MODEL_DEFAULT=anthropic/claude-sonnet-4.6
# MODEL_EMAIL=
# MODEL_LOOKUP=
# MODEL_INBOX=
# MODEL_QUEUE=
# MODEL_CAPTURE=
# MODEL_CRM=
# MODEL_TEMPORAL=
# MODEL_PREJECT=anthropic/claude-haiku-4.5
# MODEL_EVALUATOR=
# MODEL_PROMPT_BUILDER=
# MODEL_OPTIMIZER=                   # только для optimize_prompts.py
# MODEL_WIKI=                        # wiki-lint
# MODEL_RESEARCHER=                  # researcher mode

# ─── Classifier (DSPy) ──────────────────────────────────────────────────────
CLASSIFIER_MAX_TOKENS=256
# CLASSIFIER_VOTES=3                 # majority-vote, авто включается только на CC tier

# ─── Evaluator (DSPy) ───────────────────────────────────────────────────────
EVALUATOR_ENABLED=1
EVAL_SKEPTICISM=mid                  # low | mid | high
EVAL_EFFICIENCY=mid                  # low | mid | high
EVAL_MAX_REJECTIONS=2
EVALUATOR_WIKI_ENABLED=1             # подмешивать pages/<type>.md (FIX-367)
EVALUATOR_WIKI_MAX_CHARS=4000
EVALUATOR_GRAPH_TOP_K=5              # гейчено WIKI_GRAPH_ENABLED

# ─── Prompt Builder (DSPy) ──────────────────────────────────────────────────
PROMPT_BUILDER_ENABLED=1
PROMPT_BUILDER_MAX_TOKENS=500

# ─── DSPy — сбор примеров ───────────────────────────────────────────────────
DSPY_COLLECT=1                       # data/dspy_{examples,eval_examples}.jsonl
# В RESEARCHER_MODE=1 builder-примеры не собираются (addendum строит reflector).
# Evaluator-примеры собираются по RESEARCHER_EVAL_GATED=1: последний gate-call
# записывается с реальным benchmark score как ground-truth label.

# ─── DSPy COPRO (optimize_prompts.py) ───────────────────────────────────────
# Запуск вручную. Стоимость ≈ BREADTH × DEPTH × |trainset| LLM-вызовов.
# COPRO_BREADTH=4                    # кандидатов на итерацию (3–10)
# COPRO_DEPTH=2                      # итераций уточнения (1–5)
# COPRO_TEMPERATURE=0.9              # 0.0–2.0
# COPRO_THREADS=1                    # параллелизм оценки; >1 → следи за 429
# COPRO_MIN_PER_TYPE=3               # минимум примеров для per-type оптимизации
# COPRO_PROMPT_MAX_TOKENS=2000       # бюджет meta-LM для кандидатов

# ─── Ollama ─────────────────────────────────────────────────────────────────
# Модели формата name:tag (без слэша) → Ollama. Примеры: qwen3.5:cloud.
OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen3.5:cloud

# ─── Claude Code tier ───────────────────────────────────────────────────────
# Активируется префиксом claude-code/*. Stateless iclaude subprocess, OAuth.
# CC_ENABLED=1
# ICLAUDE_CMD=iclaude
# CC_STRIP_PROJECT_ENV=1             # убрать ANTHROPIC/OPENROUTER/OPENAI из env
# CC_MAX_RETRIES=2
# CC_RETRY_DELAY_S=4
# CC_DEFAULT_MODEL=sonnet
# CC_DEFAULT_EFFORT=low
# CC_DEFAULT_TIMEOUT_S=180
# CC_DEFAULT_FALLBACK_MODEL=         # --fallback-model (например "haiku")
# CC_DEFAULT_EXCLUDE_DYNAMIC=1       # убирает cwd/env/git → лучше cache reuse

# ─── Researcher mode (FIX-362) ──────────────────────────────────────────────
# Внешний цикл поверх run_loop. Без evaluator/stall/timeout в inner-loop.
# ВАЖНО: PARALLEL_TASKS=1 — иначе параллельные задачи не видят паттернов друг друга.
# RESEARCHER_MODE=0
# RESEARCHER_MAX_CYCLES=10
# RESEARCHER_STEPS_PER_CYCLE=15
# RESEARCHER_LOG_ENABLED=1           # logs/researcher/<task>/cycle_N.jsonl (vault-specific, не коммитить)

# FIX-370 — подмешивать прошлые провалы этого task_type в addendum.
# RESEARCHER_NEGATIVES_ENABLED=1
# RESEARCHER_NEGATIVES_TOP_K=3

# FIX-371 — offline short-circuit по matching Successful pattern.
# ПРЕДУПРЕЖДЕНИЕ: PAC-1 проверяет vault side-effects → score=0. Только для dev/cache-checks.
# RESEARCHER_SHORT_CIRCUIT=0
# RESEARCHER_SHORT_CIRCUIT_THRESHOLD=0.4

# FIX-372 — drift-хинт если префикс траектории не совпал ни с одним Successful pattern.
# RESEARCHER_DRIFT_HINTS=1
# RESEARCHER_DRIFT_PREFIX_LEN=3

# FIX-374 — evaluator gate как прокси benchmark score между циклами. При self-OUTCOME_OK
# или terminal refusal на cycle < MAX_CYCLES вызывает evaluate_completion; reject → inject
# EVAL_REJECTED-хинт и continue. Promotion в pages/ остаётся гейчена реальным score=1 в main.py.
# RESEARCHER_EVAL_GATED=0            # 0 = поведение до FIX-374
# RESEARCHER_EVAL_SKEPTICISM=high    # low | mid | high
# RESEARCHER_EVAL_EFFICIENCY=mid     # low | mid | high
# RESEARCHER_REFUSAL_MAX_RETRIES=3   # cap retries on terminal refusal before accepting it

# FIX-375 — OUTCOME_FLIP_HINT + diversification detector. Targets two failure modes:
# (a) reflector stuck on OUTCOME_OK while evaluator rejects repeatedly with same reason
#     (observed on t43: 15 cycles same "no exact match" interpretation);
# (b) agent refuses N times but task may be answerable under different interpretation.
# RESEARCHER_FLIP_HINT_ENABLED=1
# RESEARCHER_FLIP_REASON_SIMILARITY_THRESHOLD=0.5   # Jaccard on evaluator reason tokens
# RESEARCHER_FLIP_HYP_MONOTONIC_K=2                 # how many recent hypotheses to compare
# RESEARCHER_FLIP_HYP_SIMILARITY_THRESHOLD=0.6      # Jaccard on reflector hypothesis tokens
# RESEARCHER_REFUSAL_LAST_CHANCE=1                  # one extra cycle after refusal cap

# ─── Knowledge graph ────────────────────────────────────────────────────────
# WIKI_GRAPH_ENABLED=1
# WIKI_GRAPH_TOP_K=5
# WIKI_GRAPH_CONFIDENCE_EPSILON=0.05
# WIKI_GRAPH_MIN_CONFIDENCE=0.2      # ниже → graph_archive.json
# WIKI_PAGE_MAX_PATTERNS=10          # max `## Successful pattern:` на страницу

# ─── Wiki toggles ───────────────────────────────────────────────────────────
# WIKI_ENABLED=1                     # 0 = не писать fragments/ и не promote pages/
# WIKI_LINT_ENABLED=1                # 0 = пропустить wiki-lint до/после прогона

# ─── Tracing / debug ────────────────────────────────────────────────────────
# TRACE_ENABLED=0                    # 1 = logs/<run>/trace_<task>.jsonl
# CC_DEBUG_EMPTY=0                   # diagnostic tail при legitimately-empty CC response

# ─── HTTP таймауты LLM-клиентов ─────────────────────────────────────────────
# LLM_HTTP_READ_TIMEOUT_S=180
# LLM_HTTP_CONNECT_TIMEOUT_S=10
